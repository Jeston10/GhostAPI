# MongoDB (required for Playground provisioning + GET mocks)
MONGODB_URI=
# Optional: override database name from the connection string path
# MONGODB_DB=ghostapi

# Deploy (Vercel / other): add the same vars in the host dashboard — never commit secrets.
# Atlas → Network Access: allow your server IPs or 0.0.0.0/0 for serverless + strong password.

# Future: OpenAI-backed mock generation (not wired yet)
# OPENAI_API_KEY=

# Load testing runtime controls
# LOADTEST_V2_ENABLED=true
# LOADTEST_HISTORY_ENABLED=true
# LOADTEST_COMPARE_ENABLED=true
# LOADTEST_CI_TRIGGER_ENABLED=false
# LOADTEST_API_TOKEN=
# LOADTEST_HOST_ALLOWLIST=api.example.com,staging.example.com
# LOADTEST_MAX_ACTIVE_TESTS=3
# LOADTEST_MAX_INFLIGHT_PER_TEST=100
# LOADTEST_MEMORY_LIMIT_MB=512
